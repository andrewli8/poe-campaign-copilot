{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "windows": ["main", "settings"],
  "permissions": [
    "core:default",
    "core:window:allow-set-ignore-cursor-events",
    "core:window:allow-set-size",
    "core:window:allow-set-resizable",
    "core:window:allow-start-dragging",
    "dialog:allow-open"
  ]
}
